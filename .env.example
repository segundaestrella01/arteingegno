# Shopify Partner app credentials
# Get these from: https://partners.shopify.com → Apps → [Your App] → Client credentials
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Per-store access tokens — added automatically by: node scripts/shopify-mgr/cli.js auth <store>
# Key format: SHOPIFY_TOKEN_<SUBDOMAIN_WITH_UNDERSCORES>
SHOPIFY_TOKEN_MATTIASTORE_3117=shpat_your_token_here
